# Copia este archivo a `.env` EN EL SERVIDOR donde corra esta app (interno o DO;
# NO lo commitees). Lo leen adapter-node al arrancar (autocarga dotenv) y pm2.
PORT=3300                     # Puerto local de esta app (único por servidor)
HOST=127.0.0.1                # Siempre localhost; nginx/proxy hace el reverso
ORIGIN=https://shapeup.example.com   # Requerido por SvelteKit para aceptar POST/form-actions en prod
DATABASE_URL=./local.db       # SQLite (better-sqlite3 + drizzle)
# ADMIN_PASSWORD=             # Si tu app tiene panel admin
PUBLIC_APP_TITLE=Shape Up Buzzword   # Título visible (TopNav/home/login). Default si se omite: "Shape Up Buzzword"
